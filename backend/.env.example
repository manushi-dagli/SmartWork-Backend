# Server
PORT=4000
FRONTEND_URL=http://localhost:5173

# Better Auth
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000

# Supabase PostgreSQL (Session/Transaction pooler)
# Dashboard → Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your database password.
# Example (ap-southeast-2):
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres"

# Super admin creation (POST /api/super-admin). Set a strong secret.
SUPER_ADMIN_SECRET_KEY=your-secret-key

# JWT signing secret for employee login. Generate: openssl rand -base64 32
JWT_SECRET=your-secret-key
